  <!-- Enhanced JavaScript for Reviews System -->
  <script>
    // Reviews data structure
    const agentReviews = {
      1: { // SecureBot Pro
        name: "SecureBot Pro",
        category: "Security Auditing",
        icon: "🔒",
        rating: 4.9,
        reviewCount: 847,
        categories: {
