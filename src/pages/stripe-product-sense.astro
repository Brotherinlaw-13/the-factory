          </a>
          <a href="#product-uber" class="card !p-3 hover:bg-[rgba(226,232,240,0.6)] transition-colors text-center">
            <div class="text-2xl mb-1">🚗</div>
            <div class="text-sm text-[#0F172A] font-medium">Uber + Eats</div>
          </a>
          <a href="#product-booking" class="card !p-3 hover:bg-[rgba(226,232,240,0.6)] transition-colors text-center">
            <div class="text-2xl mb-1">🏨</div>
            <div class="text-sm text-[#0F172A] font-medium">Booking.com</div>
          </a>
