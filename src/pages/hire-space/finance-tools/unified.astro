---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Finance Tools — Unified View</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #fff; color: #1e293b; }

    /* === TOP NAV === */
    .top-nav { background: #f5f5f5; border-bottom: 1px solid #e2e8f0; padding: 12px 40px; font-size: 13px; }
    .top-nav a { color: #2563eb; text-decoration: none; margin-right: 16px; }

    /* === BOOKING SEARCH === */
    .booking-search { max-width: 1200px; margin: 0 auto; padding: 24px 40px 0; }
    .booking-search h1 { font-size: 24px; margin-bottom: 4px; }
    .booking-search .desc { color: #64748b; font-size: 14px; margin-bottom: 16px; }
    .search-bar { display: flex; gap: 12px; align-items: center; margin-bottom: 16px; }
    .search-bar input { flex: 1; padding: 10px 14px; border: 1px solid #e2e8f0; border-radius: 6px; font-size: 14px; }
    .search-bar .btn { padding: 10px 20px; }

    /* === BOOKING HEADER BAR === */
    .booking-header { background: #f0f9ff; border: 1px solid #bfdbfe; border-radius: 6px; padding: 12px 16px; margin-bottom: 20px; font-size: 13px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; }

    /* === CONTAINER === */
    .container { max-width: 1200px; margin: 0 auto; padding: 0 40px 40px; }

    /* === CSS-ONLY TABS === */
    .tab-input { display: none; }
    .tab-labels { display: flex; border-bottom: 2px solid #e2e8f0; margin-bottom: 20px; flex-wrap: wrap; }
    .tab-labels label { padding: 10px 18px; font-size: 13px; font-weight: 500; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -2px; color: #64748b; white-space: nowrap; }
    .tab-labels label:hover { color: #2563eb; }
    .tab-content { display: none; }

    #tab-overview:checked ~ .tab-labels label[for="tab-overview"],
    #tab-commission:checked ~ .tab-labels label[for="tab-commission"],
    #tab-additions:checked ~ .tab-labels label[for="tab-additions"],
    #tab-bills:checked ~ .tab-labels label[for="tab-bills"],
    #tab-paymentrun:checked ~ .tab-labels label[for="tab-paymentrun"],
    #tab-reconciliation:checked ~ .tab-labels label[for="tab-reconciliation"],
    #tab-creditnotes:checked ~ .tab-labels label[for="tab-creditnotes"],
    #tab-detective:checked ~ .tab-labels label[for="tab-detective"],
    #tab-contract:checked ~ .tab-labels label[for="tab-contract"] {
      border-bottom-color: #2563eb; color: #2563eb; font-weight: 700;
    }

    #tab-overview:checked ~ .content-overview,
    #tab-commission:checked ~ .content-commission,
    #tab-additions:checked ~ .content-additions,
    #tab-bills:checked ~ .content-bills,
    #tab-paymentrun:checked ~ .content-paymentrun,
    #tab-reconciliation:checked ~ .content-reconciliation,
    #tab-creditnotes:checked ~ .content-creditnotes,
    #tab-detective:checked ~ .content-detective,
    #tab-contract:checked ~ .content-contract {
      display: block;
    }

    /* === COMMON STYLES === */
    .card { background: #f5f5f5; border: 1px solid #e2e8f0; border-radius: 8px; padding: 20px; margin-bottom: 20px; }
    .card h3 { font-size: 14px; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th { text-align: left; padding: 8px 10px; background: #e2e8f0; font-weight: 600; font-size: 12px; color: #64748b; }
    td { padding: 8px 10px; border-bottom: 1px solid #e2e8f0; }
    .badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
    .badge-green { background: #dcfce7; color: #166534; }
    .badge-yellow { background: #fef9c3; color: #854d0e; }
    .badge-red { background: #fee2e2; color: #991b1b; }
    .badge-blue { background: #dbeafe; color: #1e40af; }
    .badge-gray { background: #f1f5f9; color: #64748b; }
    .btn { display: inline-block; padding: 8px 16px; border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer; border: none; }
    .btn-primary { background: #2563eb; color: #fff; }
    .btn-lg { padding: 14px 32px; font-size: 16px; border-radius: 8px; }
    .btn-outline { background: #fff; color: #2563eb; border: 1px solid #2563eb; }
    .btn-green { background: #16a34a; color: #fff; }
    .btn-success { background: #16a34a; color: #fff; }
    .btn-danger { background: #fff; color: #dc2626; border: 1px solid #dc2626; }
    .btn-disabled { background: #e2e8f0; color: #94a3b8; cursor: not-allowed; }
    .todo { background: #fef3c7; border-left: 3px solid #f59e0b; padding: 8px 12px; font-size: 12px; color: #92400e; margin: 8px 0; border-radius: 0 4px 4px 0; }
    .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
    .grid3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
    .kv { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #e2e8f0; font-size: 13px; }
    .kv .label { color: #64748b; }
    .big-number { font-size: 28px; font-weight: 700; color: #2563eb; }
    input[type="text"], input[type="number"], select, textarea { padding: 6px 10px; border: 1px solid #e2e8f0; border-radius: 4px; font-size: 13px; font-family: inherit; }
    .upload-zone { border: 2px dashed #e2e8f0; border-radius: 8px; padding: 24px; text-align: center; color: #94a3b8; font-size: 13px; margin-top: 8px; }
    .guardrail { background: #fee2e2; border: 1px solid #fca5a5; border-radius: 6px; padding: 12px 16px; margin-bottom: 16px; }
    .guardrail h4 { color: #991b1b; font-size: 13px; margin-bottom: 4px; }
    .guardrail p { font-size: 12px; color: #991b1b; }
    .full { grid-column: 1 / -1; }
    .action-box { border: 2px solid #2563eb; border-radius: 8px; padding: 16px; background: #eff6ff; text-align: center; }
    .filter-bar { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; margin-bottom: 20px; }
    .filter-bar select, .filter-bar input { padding: 6px 10px; border: 1px solid #e2e8f0; border-radius: 6px; font-size: 13px; }
    .alert { border-radius: 8px; padding: 16px; margin-bottom: 20px; font-size: 13px; }
    .alert-red { background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; }
    .alert-green { background: #f0fdf4; border: 1px solid #86efac; color: #166534; }
    .notification { background: #f0fdf4; border: 1px solid #86efac; border-radius: 8px; padding: 16px; }
    .warning { background: #fef3c7; border: 1px solid #fde68a; border-radius: 6px; padding: 12px 16px; font-size: 12px; color: #92400e; margin-bottom: 16px; }
    .diagnostic { background: #f8fafc; border: 1px solid #cbd5e1; border-radius: 6px; padding: 12px; font-family: monospace; font-size: 12px; color: #475569; }
    .steps { display: flex; gap: 0; margin-bottom: 24px; }
    .step { flex: 1; padding: 12px 16px; background: #f5f5f5; border: 1px solid #e2e8f0; text-align: center; font-size: 13px; color: #64748b; }
    .step.active { background: #2563eb; color: #fff; border-color: #2563eb; }
    .step.done { background: #dcfce7; color: #166534; border-color: #bbf7d0; }
    .step:first-child { border-radius: 6px 0 0 6px; }
    .step:last-child { border-radius: 0 6px 6px 0; }
    .stat-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
    .stat { background: #f5f5f5; border: 1px solid #e2e8f0; border-radius: 8px; padding: 16px; text-align: center; }
    .stat .num { font-size: 24px; font-weight: 700; }
    .stat .lbl { font-size: 12px; color: #64748b; margin-top: 4px; }
    .check-row { display: flex; align-items: center; gap: 12px; padding: 10px 0; border-bottom: 1px solid #e2e8f0; font-size: 13px; }
    .check-icon { width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; flex-shrink: 0; }
    .check-pass { background: #dcfce7; color: #166534; }
    .check-fail { background: #fee2e2; color: #991b1b; }
    .check-warn { background: #fef9c3; color: #854d0e; }
    .account-box { border: 1px solid #e2e8f0; border-radius: 6px; padding: 12px; background: #fff; text-align: center; }
    .account-box .code { font-size: 18px; font-weight: 700; color: #2563eb; }
    .account-box .name { font-size: 11px; color: #64748b; }
    .account-box .bal { font-size: 16px; font-weight: 600; margin-top: 4px; }
    .scope-badge { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 11px; font-weight: 600; margin-left: 6px; }
    .scope-booking { background: #dbeafe; color: #1e40af; }
    .scope-cross { background: #fef3c7; color: #92400e; }
    .info-banner { background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 6px; padding: 10px 16px; margin-bottom: 20px; font-size: 12px; color: #1e40af; }
  </style>
</head>
<body>

  <!-- Top Navigation -->
  <div class="top-nav">
    <a href="/hire-space/finance-tools/">← All Finance Tools</a>
    <a href="/hire-space/finance-analysis">📊 Finance Analysis</a>
  </div>

  <!-- Booking Search / Selector -->
  <div class="booking-search">
    <h1>💷 Finance Tools — Unified View</h1>
    <p class="desc">All finance workflows in one place. Select a booking to work on booking-level tabs, or jump directly to cross-booking views (Payment Run, Credit Notes).</p>
    <div class="search-bar">
      <input type="text" placeholder="Search by booking ref, venue, or client name... (e.g. HS-2026-04821)" value="HS-2026-04821" />
      <button class="btn btn-primary">🔍 Load Booking</button>
    </div>
  </div>

  <div class="container">

    <!-- Booking Header Bar (persistent) -->
    <div class="booking-header">
      <span><strong>HS-2026-04821</strong> · Moody's Corp · The Grand Ballroom, London · 15 Mar 2026 · 220 guests</span>
      <span>
        <span class="badge badge-blue">DAS — Handled</span>
        <span class="badge badge-yellow">Pending Win</span>
        <span style="font-size: 12px; color: #64748b; margin-left: 8px;">CS: Sarah Mitchell</span>
      </span>
    </div>

    <!-- CSS-only tab system -->
    <input type="radio" name="tabs" id="tab-overview" class="tab-input" checked />
    <input type="radio" name="tabs" id="tab-commission" class="tab-input" />
    <input type="radio" name="tabs" id="tab-additions" class="tab-input" />
    <input type="radio" name="tabs" id="tab-bills" class="tab-input" />
    <input type="radio" name="tabs" id="tab-paymentrun" class="tab-input" />
    <input type="radio" name="tabs" id="tab-reconciliation" class="tab-input" />
    <input type="radio" name="tabs" id="tab-creditnotes" class="tab-input" />
    <input type="radio" name="tabs" id="tab-detective" class="tab-input" />
    <input type="radio" name="tabs" id="tab-contract" class="tab-input" />

    <div class="tab-labels">
      <label for="tab-overview">📋 Overview <span class="scope-badge scope-booking">Booking</span></label>
      <label for="tab-commission">💰 Commission <span class="scope-badge scope-booking">Booking</span></label>
      <label for="tab-additions">➕ Additions <span class="scope-badge scope-booking">Booking</span></label>
      <label for="tab-bills">🧾 Bills & Payments <span class="scope-badge scope-booking">Booking</span></label>
      <label for="tab-paymentrun">🚀 Payment Run <span class="scope-badge scope-cross">All Bookings</span></label>
      <label for="tab-reconciliation">✅ Reconciliation <span class="scope-badge scope-booking">Booking</span></label>
      <label for="tab-creditnotes">📝 Credit Notes <span class="scope-badge scope-cross">All Bookings</span></label>
      <label for="tab-detective">🔍 Invoice Detective <span class="scope-badge scope-cross">All Bookings</span></label>
      <label for="tab-contract">📑 Contract & Winning <span class="scope-badge scope-booking">Booking</span></label>
    </div>

    <!-- ==================== TAB 1: OVERVIEW ==================== -->
    <div class="tab-content content-overview">

      <div class="grid2">
        <div class="card">
          <h3>Booking Details</h3>
          <div class="kv"><span class="label">Booking ID</span><span>HS-2026-04821</span></div>
          <div class="kv"><span class="label">Client</span><span>Moody's Corp</span></div>
          <div class="kv"><span class="label">Venue</span><span>The Grand Ballroom, London</span></div>
          <div class="kv"><span class="label">Event Date</span><span>15 Mar 2026</span></div>
          <div class="kv"><span class="label">Event Type</span><span>Annual Gala Dinner</span></div>
          <div class="kv"><span class="label">Guests</span><span>220</span></div>
          <div class="kv"><span class="label">Booking Type</span><span><span class="badge badge-blue">Handled — DAS</span></span></div>
          <div class="kv"><span class="label">CS Owner</span><span>Sarah Mitchell</span></div>
          <div class="kv"><span class="label">Status</span><span><span class="badge badge-yellow">Pending Win</span></span></div>
        </div>
        <div class="card">
          <h3>Contract & Documents</h3>
          <div class="kv"><span class="label">Juro Contract</span><span><span class="badge badge-green">Countersigned ✓</span></span></div>
          <div class="kv"><span class="label">T&Cs Version</span><span>v4.2 (Jan 2026)</span></div>
          <div class="kv"><span class="label">Quote Filled</span><span><span class="badge badge-green">Yes ✓</span></span></div>
          <div class="kv"><span class="label">Venue T&Cs</span><span><span class="badge badge-yellow">Awaiting upload</span></span></div>
          <div style="margin-top: 16px;">
            <strong style="font-size: 12px; color: #64748b;">Upload Signed Contract / T&Cs</strong>
            <div class="upload-zone">📎 Drag & drop or click to upload PDF</div>
          </div>
          <div class="todo">[TODO] Should Juro status pull automatically from Juro API, or manual confirmation?</div>
        </div>
      </div>

      <!-- Commission Summary -->
      <div class="card">
        <h3>Commission Summary — Per Line Item</h3>
        <div class="todo">[TODO] Should commission % be editable here, or locked from contract? Who can override?</div>
        <table style="margin-top: 12px;">
          <thead>
            <tr><th>Line Item</th><th>Gross (ex VAT)</th><th>Commission %</th><th>Commission £</th><th>Net to Venue</th><th>Type</th></tr>
          </thead>
          <tbody>
            <tr><td>Room hire</td><td>£8,500.00</td><td>15%</td><td>£1,275.00</td><td>£7,225.00</td><td><span class="badge badge-blue">DAS</span></td></tr>
            <tr><td>Catering — 3-course dinner × 220</td><td>£17,600.00</td><td>12%</td><td>£2,112.00</td><td>£15,488.00</td><td><span class="badge badge-blue">DAS</span></td></tr>
            <tr><td>AV & lighting package</td><td>£3,200.00</td><td>10%</td><td>£320.00</td><td>£2,880.00</td><td><span class="badge badge-blue">DAS</span></td></tr>
            <tr><td>Drinks reception (champagne)</td><td>£2,640.00</td><td>12%</td><td>£316.80</td><td>£2,323.20</td><td><span class="badge badge-blue">DAS</span></td></tr>
            <tr style="background: #f0f9ff; font-weight: 600;">
              <td>TOTAL</td><td>£31,940.00</td><td>—</td><td>£4,023.80</td><td>£27,916.20</td><td></td>
            </tr>
          </tbody>
        </table>
        <div class="todo">[TODO] How to handle mixed DAS/DAC items on the same booking? Show separate totals?</div>
      </div>

      <!-- Guard Rails -->
      <div class="card">
        <h3>🛡️ Guard Rails — Pre-Win Checks</h3>
        <p style="font-size: 12px; color: #64748b; margin-bottom: 12px;">All checks must pass before the "Mark as Won" button is enabled.</p>
        <table>
          <thead><tr><th>Check</th><th>Status</th><th>Detail</th></tr></thead>
          <tbody>
            <tr><td>Contract countersigned in Juro</td><td><span class="badge badge-green">Pass ✓</span></td><td>Signed 10 Feb 2026</td></tr>
            <tr><td>Quote filled with all line items</td><td><span class="badge badge-green">Pass ✓</span></td><td>4 items, £31,940 total</td></tr>
            <tr><td>Commission % within allowed range</td><td><span class="badge badge-green">Pass ✓</span></td><td>All items 10-15% (policy: 8-20%)</td></tr>
            <tr><td>Commission summary reviewed (£ amounts)</td><td><span class="badge badge-yellow">Pending</span></td><td>CS must click "Confirm commission"</td></tr>
            <tr><td>Venue T&Cs uploaded</td><td><span class="badge badge-red">Fail ✗</span></td><td>Missing — upload above</td></tr>
            <tr><td>No duplicate booking</td><td><span class="badge badge-green">Pass ✓</span></td><td>No match found</td></tr>
          </tbody>
        </table>
        <div class="todo">[TODO] What are the exact commission % guardrail ranges? Should they vary by venue tier?</div>
        <div class="todo">[TODO] Should any guard rails be soft warnings (allow override) vs hard blocks?</div>
      </div>

      <!-- Actions -->
      <div style="display: flex; gap: 12px; align-items: center; margin-top: 8px;">
        <button class="btn btn-outline">Confirm Commission Summary</button>
        <button class="btn btn-disabled" title="1 guard rail failing">🔒 Mark as Won</button>
        <span style="font-size: 12px; color: #991b1b;">⚠ 1 guard rail failing — resolve before winning</span>
      </div>

      <div class="guardrail" style="margin-top: 24px;">
        <h4>⚠ Cannot Win Booking</h4>
        <p>Venue T&Cs have not been uploaded. Please upload the signed venue terms before marking this booking as won.</p>
      </div>
    </div>

    <!-- ==================== TAB 2: COMMISSION ==================== -->
    <div class="tab-content content-commission">

      <div class="alert alert-red">
        <strong>⚠️ Background:</strong> DAC auto-invoicing was disabled due to a 150% markup bug that overcharged venues. Since then, all DAC commission invoices have been generated manually — or not at all. This tool re-enables automated commission generation with proper guards, preview, and audit trail.
      </div>

      <!-- Status Dashboard -->
      <div class="grid3" style="margin-bottom: 24px;">
        <div class="card" style="text-align: center;">
          <h3>Pending Commissions</h3>
          <div class="big-number" style="color: #ef4444;">23</div>
          <span style="font-size: 12px; color: #64748b;">bookings with no commission invoice</span>
        </div>
        <div class="card" style="text-align: center;">
          <h3>Generated This Month</h3>
          <div class="big-number" style="color: #22c55e;">47</div>
          <span style="font-size: 12px; color: #64748b;">commission invoices created</span>
        </div>
        <div class="card" style="text-align: center;">
          <h3>Pending Value</h3>
          <div class="big-number">£18,420</div>
          <span style="font-size: 12px; color: #64748b;">estimated unbilled commission</span>
        </div>
      </div>

      <div class="todo">[TODO] Should pending commissions include only post-event bookings, or also upcoming confirmed bookings? What's the trigger point for commission eligibility?</div>

      <!-- Filter Bar -->
      <div class="card">
        <h3>Filter Bookings</h3>
        <div class="filter-bar">
          <select><option>All Types</option><option>DAS Only</option><option>DAC Only</option></select>
          <select><option>Pending Commission</option><option>Generated</option><option>All Statuses</option></select>
          <select><option>Last 30 days</option><option>Last 60 days</option><option>Last 90 days</option><option>Custom range</option></select>
          <input type="text" placeholder="Search booking ref or venue..." style="flex: 1; min-width: 180px;" />
          <button class="btn btn-outline">🔍 Filter</button>
        </div>
        <div class="todo">[TODO] Should there be a venue filter dropdown? Also: should we show bookings where event hasn't happened yet?</div>
      </div>

      <!-- Commission Queue -->
      <div class="card">
        <h3>Commission Queue</h3>
        <table>
          <thead>
            <tr><th><input type="checkbox" title="Select all" /></th><th>Booking Ref</th><th>Venue</th><th>Event Date</th><th>Type</th><th>Booking Value (ex VAT)</th><th>Rate</th><th>Commission</th><th>Status</th><th>Action</th></tr>
          </thead>
          <tbody>
            <tr>
              <td><input type="checkbox" /></td><td>HS-2026-04821</td><td>The Grand Ballroom</td><td>15 Mar 2026</td><td><span class="badge badge-blue">DAS</span></td><td>£31,940.00</td><td>12.6%</td><td>£4,023.80</td><td><span class="badge badge-yellow">Pending</span></td><td><button class="btn btn-primary" style="padding: 4px 10px; font-size: 11px;">Generate</button></td>
            </tr>
            <tr>
              <td><input type="checkbox" /></td><td>HS-2026-04799</td><td>Riverside Venue</td><td>12 Mar 2026</td><td><span class="badge badge-yellow">DAC</span></td><td>£8,500.00</td><td>15%</td><td>£1,275.00</td><td><span class="badge badge-yellow">Pending</span></td><td><button class="btn btn-primary" style="padding: 4px 10px; font-size: 11px;">Generate</button></td>
            </tr>
            <tr>
              <td><input type="checkbox" /></td><td>HS-2026-04756</td><td>City Conference Centre</td><td>10 Mar 2026</td><td><span class="badge badge-yellow">DAC</span></td><td>£14,200.00</td><td>12%</td><td>£1,704.00</td><td><span class="badge badge-yellow">Pending</span></td><td><button class="btn btn-primary" style="padding: 4px 10px; font-size: 11px;">Generate</button></td>
            </tr>
            <tr style="opacity: 0.6;">
              <td><input type="checkbox" disabled /></td><td>HS-2026-04712</td><td>The Shard Events</td><td>8 Mar 2026</td><td><span class="badge badge-blue">DAS</span></td><td>£22,000.00</td><td>10%</td><td>£2,200.00</td><td><span class="badge badge-green">Generated</span></td><td><span style="font-size: 11px; color: #64748b;">INV-4712</span></td>
            </tr>
            <tr style="opacity: 0.6;">
              <td><input type="checkbox" disabled /></td><td>HS-2026-04698</td><td>Merchant Taylors' Hall</td><td>5 Mar 2026</td><td><span class="badge badge-blue">DAS</span></td><td>£45,000.00</td><td>12%</td><td>£5,400.00</td><td><span class="badge badge-green">Generated</span></td><td><span style="font-size: 11px; color: #64748b;">INV-4698</span></td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Commission Preview (expanded) -->
      <div class="card">
        <h3>Commission Preview — HS-2026-04799 (DAC)</h3>
