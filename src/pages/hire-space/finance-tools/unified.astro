<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Finance Tools — Unified View</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #fff; color: #1e293b; }
    .top-nav { background: #f5f5f5; border-bottom: 1px solid #e2e8f0; padding: 12px 40px; font-size: 13px; }
    .top-nav a { color: #2563eb; text-decoration: none; margin-right: 16px; }
    .booking-search { max-width: 1200px; margin: 0 auto; padding: 24px 40px 0; }
    .booking-search h1 { font-size: 24px; margin-bottom: 4px; }
    .booking-search .desc { color: #64748b; font-size: 14px; margin-bottom: 16px; }
    .search-bar { display: flex; gap: 12px; align-items: center; margin-bottom: 16px; }
    .search-bar input { flex: 1; padding: 10px 14px; border: 1px solid #e2e8f0; border-radius: 6px; font-size: 14px; }
    .search-bar .btn { padding: 10px 20px; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 40px 40px; }
    .tab-input { display: none; }
    .top-tab-labels { display: flex; border-bottom: 3px solid #e2e8f0; }
    .top-tab-labels label { padding: 14px 28px; font-size: 15px; font-weight: 600; cursor: pointer; border-bottom: 3px solid transparent; margin-bottom: -3px; color: #64748b; }
    .top-tab-labels label:hover { color: #2563eb; background: #f8fafc; }
    .top-tab-content { display: none; }
    #tab-booking:checked ~ .top-tab-labels label[for="tab-booking"],
    #tab-ops:checked ~ .top-tab-labels label[for="tab-ops"] { border-bottom-color: #2563eb; color: #2563eb; font-weight: 700; background: #eff6ff; }
    #tab-booking:checked ~ .content-booking,
    #tab-ops:checked ~ .content-ops { display: block; }
    .booking-system-header { background: #1e293b; color: #fff; padding: 16px 24px; border-radius: 8px 8px 0 0; margin-top: 20px; }
    .booking-system-header .booking-ref { font-size: 20px; font-weight: 700; }
    .booking-system-header .booking-meta { font-size: 13px; color: #94a3b8; margin-top: 4px; }
    .booking-system-header .booking-meta span { margin-right: 16px; }
    .booking-system-tabs { display: flex; background: #334155; border-radius: 0 0 8px 8px; overflow: hidden; margin-bottom: 24px; }
    .booking-system-tabs .sys-tab { padding: 10px 20px; font-size: 13px; color: #94a3b8; cursor: default; border-bottom: 2px solid transparent; }
    .booking-system-tabs .sys-tab.active { color: #fff; background: #475569; border-bottom-color: #3b82f6; font-weight: 600; }
    .section-header { font-size: 18px; font-weight: 700; color: #1e293b; margin: 32px 0 16px; padding-bottom: 8px; border-bottom: 2px solid #e2e8f0; }
    .card { background: #f5f5f5; border: 1px solid #e2e8f0; border-radius: 8px; padding: 20px; margin-bottom: 20px; }
    .card h3 { font-size: 14px; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th { text-align: left; padding: 8px 10px; background: #e2e8f0; font-weight: 600; font-size: 12px; color: #64748b; }
    td { padding: 8px 10px; border-bottom: 1px solid #e2e8f0; }
    .badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
    .badge-green { background: #dcfce7; color: #166534; }
    .badge-yellow { background: #fef9c3; color: #854d0e; }
    .badge-red { background: #fee2e2; color: #991b1b; }
    .badge-blue { background: #dbeafe; color: #1e40af; }
    .badge-gray { background: #f1f5f9; color: #64748b; }
    .btn { display: inline-block; padding: 8px 16px; border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer; border: none; }
    .btn-primary { background: #2563eb; color: #fff; }
    .btn-lg { padding: 14px 32px; font-size: 16px; border-radius: 8px; }
    .btn-outline { background: #fff; color: #2563eb; border: 1px solid #2563eb; }
    .btn-green { background: #16a34a; color: #fff; }
    .btn-success { background: #16a34a; color: #fff; }
    .btn-danger { background: #fff; color: #dc2626; border: 1px solid #dc2626; }
    .btn-disabled { background: #e2e8f0; color: #94a3b8; cursor: not-allowed; }
    .todo { background: #fef3c7; border-left: 3px solid #f59e0b; padding: 8px 12px; font-size: 12px; color: #92400e; margin: 8px 0; border-radius: 0 4px 4px 0; }
    .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
    .grid3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
    .kv { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #e2e8f0; font-size: 13px; }
    .kv .label { color: #64748b; }
    .big-number { font-size: 28px; font-weight: 700; color: #2563eb; }
    input[type="text"], input[type="number"], select, textarea { padding: 6px 10px; border: 1px solid #e2e8f0; border-radius: 4px; font-size: 13px; font-family: inherit; }
    .upload-zone { border: 2px dashed #e2e8f0; border-radius: 8px; padding: 24px; text-align: center; color: #94a3b8; font-size: 13px; margin-top: 8px; }
    .guardrail { background: #fee2e2; border: 1px solid #fca5a5; border-radius: 6px; padding: 12px 16px; margin-bottom: 16px; }
    .guardrail h4 { color: #991b1b; font-size: 13px; margin-bottom: 4px; }
    .guardrail p { font-size: 12px; color: #991b1b; }
    .action-box { border: 2px solid #2563eb; border-radius: 8px; padding: 16px; background: #eff6ff; text-align: center; }
    .filter-bar { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
    .filter-bar select, .filter-bar input { padding: 6px 10px; border: 1px solid #e2e8f0; border-radius: 6px; font-size: 13px; }
    .alert { border-radius: 8px; padding: 16px; margin-bottom: 20px; font-size: 13px; }
    .alert-red { background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; }
    .notification { background: #f0fdf4; border: 1px solid #86efac; border-radius: 8px; padding: 16px; margin-bottom: 20px; }
    .diagnostic { background: #f8fafc; border: 1px solid #cbd5e1; border-radius: 6px; padding: 12px; font-family: monospace; font-size: 12px; color: #475569; }
    .steps { display: flex; gap: 0; margin-bottom: 24px; }
    .step { flex: 1; padding: 12px 16px; background: #f5f5f5; border: 1px solid #e2e8f0; text-align: center; font-size: 13px; color: #64748b; }
    .step.active { background: #2563eb; color: #fff; border-color: #2563eb; }
    .step.done { background: #dcfce7; color: #166534; border-color: #bbf7d0; }
    .step:first-child { border-radius: 6px 0 0 6px; }
    .step:last-child { border-radius: 0 6px 6px 0; }
    .stat-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
    .stat { background: #f5f5f5; border: 1px solid #e2e8f0; border-radius: 8px; padding: 16px; text-align: center; }
    .stat .num { font-size: 24px; font-weight: 700; }
    .stat .lbl { font-size: 12px; color: #64748b; margin-top: 4px; }
    .check-row { display: flex; align-items: center; gap: 12px; padding: 10px 0; border-bottom: 1px solid #e2e8f0; font-size: 13px; }
    .check-icon { width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; flex-shrink: 0; }
    .check-pass { background: #dcfce7; color: #166534; }
    .check-fail { background: #fee2e2; color: #991b1b; }
    .check-warn { background: #fef9c3; color: #854d0e; }
    .account-box { border: 1px solid #e2e8f0; border-radius: 6px; padding: 12px; background: #fff; text-align: center; }
    .account-box .code { font-size: 18px; font-weight: 700; color: #2563eb; }
    .account-box .name { font-size: 11px; color: #64748b; }
    .account-box .bal { font-size: 16px; font-weight: 600; margin-top: 4px; }
    .info-banner { background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 6px; padding: 10px 16px; margin-bottom: 20px; font-size: 12px; color: #1e40af; }
  </style>
</head>
