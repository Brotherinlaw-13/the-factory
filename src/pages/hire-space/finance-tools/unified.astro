#l2f-commission:checked~.l2f-c-commission,#l2f-payruns:checked~.l2f-c-payruns,#l2f-detective:checked~.l2f-c-detective,#l2f-missing:checked~.l2f-c-missing{display:block}
.badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;white-space:nowrap}
.badge-green{background:#dcfce7;color:#166534}.badge-yellow{background:#fef9c3;color:#854d0e}.badge-red{background:#fee2e2;color:#991b1b}.badge-blue{background:#dbeafe;color:#1e40af}.badge-gray{background:#f1f5f9;color:#64748b}.badge-purple{background:#f3e8ff;color:#6b21a8}
.card{background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:20px;margin-bottom:16px}
.card h3{font-size:13px;color:#64748b;text-transform:uppercase;letter-spacing:.5px;margin-bottom:12px}
.stitle{font-size:17px;font-weight:700;color:#1e293b;margin:28px 0 14px;padding-bottom:8px;border-bottom:2px solid #e2e8f0}
table{width:100%;border-collapse:collapse;font-size:13px}
th{text-align:left;padding:8px 10px;background:#f8fafc;font-weight:600;font-size:12px;color:#64748b;border-bottom:1px solid #e2e8f0}
td{padding:8px 10px;border-bottom:1px solid #f1f5f9}
.btn{display:inline-block;padding:8px 16px;border-radius:6px;font-size:13px;font-weight:600;cursor:pointer;border:none}
.btn-primary{background:#2563eb;color:#fff}.btn-outline{background:#fff;color:#2563eb;border:1px solid #2563eb}.btn-green{background:#16a34a;color:#fff}.btn-disabled{background:#e2e8f0;color:#94a3b8;cursor:not-allowed}
.btn-sm{padding:4px 10px;font-size:11px}.btn-lg{padding:14px 32px;font-size:16px;border-radius:8px}
.todo{background:#fef3c7;border-left:3px solid #f59e0b;padding:10px 14px;font-size:12px;color:#92400e;margin:12px 0;border-radius:0 4px 4px 0}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:16px}.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px}
.kv{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #f1f5f9;font-size:13px}.kv .label{color:#64748b}
.big-number{font-size:28px;font-weight:700;color:#2563eb}
.steps{display:flex;gap:0;margin-bottom:20px}.step{flex:1;padding:10px 12px;background:#f5f5f5;border:1px solid #e2e8f0;text-align:center;font-size:12px;color:#64748b}.step.active{background:#2563eb;color:#fff;border-color:#2563eb;font-weight:600}.step.done{background:#dcfce7;color:#166534;border-color:#bbf7d0}.step:first-child{border-radius:6px 0 0 6px}.step:last-child{border-radius:0 6px 6px 0}
.stat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:20px}.stat{background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:16px;text-align:center}.stat .num{font-size:24px;font-weight:700}.stat .lbl{font-size:12px;color:#64748b;margin-top:4px}
.check-row{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid #f1f5f9;font-size:13px}.check-icon{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0}.check-pass{background:#dcfce7;color:#166534}.check-fail{background:#fee2e2;color:#991b1b}.check-warn{background:#fef9c3;color:#854d0e}
.account-box{border:1px solid #e2e8f0;border-radius:6px;padding:12px;background:#fff;text-align:center}.account-box .code{font-size:18px;font-weight:700;color:#2563eb}.account-box .name{font-size:11px;color:#64748b}.account-box .bal{font-size:16px;font-weight:600;margin-top:4px}
.action-box{border:2px solid #2563eb;border-radius:8px;padding:20px;background:#eff6ff;text-align:center;margin:20px 0}
.upload-zone{border:2px dashed #cbd5e1;border-radius:8px;padding:24px;text-align:center;color:#94a3b8;font-size:13px}
.guardrail{background:#fee2e2;border:1px solid #fca5a5;border-radius:6px;padding:12px 16px;margin-bottom:16px}.guardrail h4{color:#991b1b;font-size:13px;margin-bottom:4px}.guardrail p{font-size:12px;color:#991b1b}
.info-banner{background:#eff6ff;border:1px solid #bfdbfe;border-radius:6px;padding:10px 16px;margin-bottom:16px;font-size:12px;color:#1e40af}
.notification{background:#f0fdf4;border:1px solid #86efac;border-radius:8px;padding:16px;margin-bottom:16px}
.filter-bar{display:flex;gap:12px;align-items:center;flex-wrap:wrap;margin-bottom:16px}.filter-bar select,.filter-bar input{padding:6px 10px;border:1px solid #e2e8f0;border-radius:6px;font-size:13px}
input[type="text"],select{padding:6px 10px;border:1px solid #e2e8f0;border-radius:4px;font-size:13px;font-family:inherit}
.alert-red{background:#fef2f2;border:1px solid #fecaca;color:#991b1b;border-radius:8px;padding:14px;margin-bottom:16px;font-size:13px}
/* ── Contracts tab: compact summary header ── */
.contract-summary-header{display:flex;align-items:center;gap:20px;flex-wrap:wrap;background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:12px 20px;margin-bottom:16px}
.csh-item{font-size:13px;color:#1e293b}.csh-label{font-size:11px;color:#64748b;display:block}
/* ── Quick actions row ── */
.quick-actions-row{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px}
.quick-actions-row label{cursor:pointer}
/* ── CSS-only modals (checkbox hack) ── */
.css-modal{display:none;position:fixed;inset:0;z-index:1000;align-items:center;justify-content:center}
#modal-downstream:checked~.l1-c-contracts .css-modal#modal-overlay-downstream{display:flex}
#modal-win-ctr1:checked~.l1-c-contracts .css-modal#modal-overlay-win-ctr1{display:flex}
#modal-payment-run:checked~.l1-c-invoices .css-modal#modal-overlay-payment-run{display:flex}
.css-modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);cursor:pointer}
.css-modal-content{position:relative;background:#fff;border-radius:10px;padding:0;max-width:600px;width:90%;max-height:80vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.2);z-index:1}
.css-modal-header{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid #e2e8f0}
.css-modal-header h3{font-size:16px;font-weight:700;color:#1e293b;margin:0;text-transform:none;letter-spacing:0}
.css-modal-close{font-size:20px;color:#64748b;cursor:pointer;padding:4px 8px;border-radius:4px;line-height:1}
.css-modal-close:hover{background:#f1f5f9;color:#1e293b}
.css-modal-body{padding:20px}
/* ── Collapsible sections (details/summary) ── */
.collapse-section{margin-bottom:8px}
.collapse-trigger{cursor:pointer;font-size:13px;color:#2563eb;font-weight:500;padding:6px 0;list-style:none}
.collapse-trigger::-webkit-details-marker{display:none}
.collapse-trigger::before{content:'▸ ';font-size:12px}
details[open]>.collapse-trigger::before{content:'▾ '}
/* ── Booking line accordion ── */
details>summary::-webkit-details-marker{display:none}
details>summary::marker{display:none}
/* ── Mini contract lifecycle stepper (per booking line) ── */
.step-mini{flex:1;padding:6px 8px;background:#f5f5f5;border:1px solid #e2e8f0;text-align:center;font-size:10px;color:#94a3b8}
.step-mini.step-mini-done{background:#dcfce7;color:#166534;border-color:#bbf7d0}
.step-mini.step-mini-active{background:#2563eb;color:#fff;border-color:#2563eb;font-weight:600}
.step-mini:first-child{border-radius:4px 0 0 4px}
.step-mini:last-child{border-radius:0 4px 4px 0}
/* ── Per-line contract accordion ── */
.line-contract-accordion>summary{user-select:none}
.line-contract-accordion>summary::-webkit-details-marker{display:none}
.line-contract-accordion>summary::marker{display:none}
/* ── Contracts tab: sidebar + main layout ── */
.ctr-layout{display:flex;gap:0;min-height:600px;border:1px solid #e2e8f0;border-radius:8px;overflow:hidden;background:#fff;margin-bottom:24px}
.ctr-sidebar{width:260px;background:#f8fafc;border-right:1px solid #e2e8f0;flex-shrink:0;padding:12px 0}
.ctr-sidebar-item{display:block;padding:12px 16px;border-left:3px solid transparent;cursor:pointer;font-size:13px;border-bottom:1px solid #e2e8f0}
.ctr-sidebar-item:hover{background:#f0f9ff}
.ctr-sidebar-item .ctr-name{font-weight:700;font-size:14px;color:#1e293b;display:block}
.ctr-sidebar-item .ctr-meta{font-size:11px;color:#64748b;display:block;margin-top:2px}
.ctr-sidebar-item .ctr-value{font-size:12px;color:#2563eb;font-weight:600}
.ctr-main{flex:1;padding:24px;overflow-y:auto}
.ctr-topbar{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;padding-bottom:16px;border-bottom:1px solid #e2e8f0;margin-bottom:20px}
.ctr-topbar h2{font-size:18px;font-weight:700;margin:0}
.ctr-subtabs{display:flex;gap:0;border:1px solid #e2e8f0;border-radius:6px;overflow:hidden;margin-bottom:20px}
.ctr-subtabs label{padding:10px 20px;font-size:13px;font-weight:500;color:#64748b;cursor:pointer;border-right:1px solid #e2e8f0;background:#fff}
.ctr-subtabs label:last-child{border-right:none}
.ctr-subtabs label:hover{background:#f0f9ff;color:#2563eb}
.ctr-sub-c{display:none}
.ctr-section{margin-bottom:24px}
.ctr-section h4{font-size:13px;color:#64748b;text-transform:uppercase;letter-spacing:.5px;margin-bottom:12px}
.upload-box{border:2px dashed #cbd5e1;border-radius:6px;padding:10px;text-align:center;color:#94a3b8;font-size:12px;width:120px;height:60px;display:flex;align-items:center;justify-content:center}
.contact-list{border:1px solid #e2e8f0;border-radius:6px;overflow:hidden;font-size:12px}
.contact-item{padding:8px 12px;border-bottom:1px solid #f1f5f9;display:flex;align-items:center;gap:8px;cursor:pointer}
.contact-item:hover{background:#f0f9ff}
.contact-item.selected{background:#eff6ff;border-left:3px solid #2563eb}
.win-contract-box{border:2px solid #16a34a;border-radius:8px;padding:20px;background:#f0fdf4;margin-top:24px}
#ctr-select-1:checked~.ctr-layout .ctr-sidebar-item:nth-child(1){background:#fff;border-left-color:#2563eb}
#ctr-select-1:checked~.ctr-layout .ctr-main-1{display:block}
#ctr-select-2:checked~.ctr-layout .ctr-sidebar-item:nth-child(2){background:#fff;border-left-color:#2563eb}
#ctr-select-2:checked~.ctr-layout .ctr-main-2{display:block}
.ctr-main-1,.ctr-main-2{display:none}
#ctr-sub-details:checked~.ctr-subtabs label[for="ctr-sub-details"]{background:#eff6ff;color:#2563eb;font-weight:700}
#ctr-sub-details:checked~.ctr-sub-c-details{display:block}
#ctr-sub-payments:checked~.ctr-subtabs label[for="ctr-sub-payments"]{background:#eff6ff;color:#2563eb;font-weight:700}
#ctr-sub-payments:checked~.ctr-sub-c-payments{display:block}
#ctr-sub-cancel:checked~.ctr-subtabs label[for="ctr-sub-cancel"]{background:#eff6ff;color:#2563eb;font-weight:700}
#ctr-sub-cancel:checked~.ctr-sub-c-cancel{display:block}
#ctr-sub-timesold:checked~.ctr-subtabs label[for="ctr-sub-timesold"]{background:#eff6ff;color:#2563eb;font-weight:700}
#ctr-sub-timesold:checked~.ctr-sub-c-timesold{display:block}
</style>
</head>
