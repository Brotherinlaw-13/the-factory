        <span style="color: var(--color-stone);">·</span>
        <a href="/stripe-mocks/v4/atm-aeropuerto" class="text-sm hover:opacity-80" style="color: var(--color-primary);">ATM aeropuerto →</a>
      </div>

    </div>
  </div>
</LightLayout>
