---
import LightLayout from '../../layouts/LightLayout.astro';

const fullInterviews = [
  { slug: 'whatsapp', title: 'WhatsApp', transplant: 'Mayores de 70', icon: '💬', summary: 'Identidad por número. Trasplante que cuestiona supuestos de raíz.' },
  { slug: 'google-maps', title: 'Google Maps', transplant: 'Zonas rurales', icon: '🗺️', summary: '6 segmentos. La "feature invisible" como frame. Sistema social geocercado.' },
  { slug: 'steam', title: 'Steam', transplant: 'Creator-first', icon: '🎮', summary: 'Marketplace + plataforma + social. La pregunta del 30% gestionada.' },
  { slug: 'github', title: 'GitHub', transplant: 'Non-coders', icon: '🐙', summary: 'PR como unidad atómica. Adquisición Microsoft con datos.' },
  { slug: 'claude-code', title: 'Claude Code', transplant: 'Non-developers', icon: '⚡', summary: 'Asistente vs colaborador. Slip + auto-recuperación elegante.' },
  { slug: 'youtube', title: 'YouTube', transplant: 'Niños <10', icon: '📺', summary: '4 segmentos contradictorios. Momento de presión real (consumer vs decisor).' },
];

const angles = [
  { slug: 'whatsapp-angles', title: 'WhatsApp', icon: '💬', q1: 'Improve para small business', q2: 'Kill or invest sobre Status' },
  { slug: 'atm-angles', title: 'ATM Aeropuerto', icon: '✈️', q1: 'Métricas deep dive', q2: 'Scale to 100 airports' },
  { slug: 'claude-code-angles', title: 'Claude Code', icon: '⚡', q1: 'Diseña pricing', q2: 'Compete con Cursor' },
  { slug: 'youtube-angles', title: 'YouTube', icon: '📺', q1: 'Diseña Shorts from scratch', q2: 'Arregla monetización del mid-creator' },
];

const atms = [
  { slug: 'atm-aeropuerto', title: 'Aeropuerto', icon: '✈️', insight: 'Sub-segmentación turista/business/migrante' },
  { slug: 'atm-hospital', title: 'Hospital', icon: '🏥', insight: 'Primary user contraintuitivo: acompañante' },
  { slug: 'atm-campus', title: 'Campus', icon: '🎓', insight: 'Reframe a hub financiero estudiantil internacional' },
  { slug: 'atm-estacion', title: 'Estación commuter', icon: '🚆', insight: 'Subordinación total a velocidad. 15 segundos.' },
  { slug: 'atm-pueblo', title: 'Pueblo rural', icon: '🏘️', insight: 'Infraestructura social, no producto comercial' },
];

const guiones = [
  { slug: 'google-maps', title: 'Google Maps', icon: '🗺️', anchor: '"Información correcta = accionable ahora"' },
  { slug: 'steam', title: 'Steam', icon: '🎮', anchor: '"Steam es el SO del gaming PC"' },
  { slug: 'github', title: 'GitHub', icon: '🐙', anchor: '"PR = unidad atómica de comunicación"' },
  { slug: 'whatsapp', title: 'WhatsApp', icon: '💬', anchor: '"El círculo cerrado de confianza"' },
  { slug: 'claude-code', title: 'Claude Code', icon: '⚡', anchor: '"Colaborador, no asistente"' },
  { slug: 'youtube', title: 'YouTube', icon: '📺', anchor: '"Implementación brillante ≠ ética"' },
];
---

<LightLayout title="Stripe Product Sense — Mock Interviews" description="Hub navegable de mock interviews y worked examples para la entrevista de Stripe Product Sense del 22 may 2026.">

  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-16 md:pt-24 pb-8">
    <div class="flex items-center gap-3 mb-6">
      <span class="text-5xl">🎙️</span>
      <div>
        <div class="flex items-center gap-3 flex-wrap">
          <h1 class="text-4xl md:text-5xl font-black" style="color: var(--color-graphite);">Mock Interviews Hub</h1>
          <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider" style="background: var(--color-primary-soft); color: var(--color-primary);">Stripe Prep</span>
        </div>
        <p class="font-medium mt-1" style="color: var(--color-primary);">Viernes 22 May 2026 • 15 piezas · navegables</p>
      </div>
    </div>

    <p class="text-xl leading-relaxed max-w-3xl mb-8" style="color: var(--color-stone);">
      Material en tres formatos: entrevistas completas con transcripción anotada (6), ángulos alternativos sobre productos (8 mini), y ATM-style design-from-scratch (5). Léelos sueltos en el orden que prefieras.
    </p>

    <div class="flex gap-3 flex-wrap mb-8">
      <a href="/stripe-product-sense" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border text-sm hover:opacity-80" style="background: var(--color-primary-soft); border-color: rgba(139,92,246,0.2); color: var(--color-primary);">
        <span>📋</span><span>Dossier</span>
      </a>
      <a href="/stripe-product-sense-leaks" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border text-sm hover:opacity-80" style="background: var(--color-primary-soft); border-color: rgba(139,92,246,0.2); color: var(--color-primary);">
        <span>🔍</span><span>Recon</span>
      </a>
      <a href="/stripe-product-sense-reps" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border text-sm hover:opacity-80" style="background: var(--color-primary-soft); border-color: rgba(139,92,246,0.2); color: var(--color-primary);">
        <span>🎯</span><span>Reps</span>
      </a>
      <a href="/stripe-capital-domain" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border text-sm hover:opacity-80" style="background: var(--color-primary-soft); border-color: rgba(139,92,246,0.2); color: var(--color-primary);">
        <span>💳</span><span>Capital domain</span>
      </a>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 pb-16">

    <div class="card !p-5 mb-8" style="background: linear-gradient(135deg, rgba(139,92,246,0.10), rgba(236,72,153,0.10)); border: 1px solid rgba(139,92,246,0.30);">
      <div class="flex items-start gap-3">
        <span class="text-3xl">📝</span>
        <div class="flex-1">
          <h3 class="text-xl font-bold !my-0" style="color: var(--color-graphite);">Guiones estructurados <span class="text-sm font-normal" style="color: var(--color-primary);">· nuevo, para leer en voz alta</span></h3>
          <p class="text-sm !my-2" style="color: var(--color-stone);">Bloques etiquetados (usuario → ecosistema → propuesta → riesgos → métricas → trasplante → presión), con anotaciones del patrón al margen. Lee, repite, internaliza. La estructura cuando no la voz.</p>
        </div>
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-3 mb-12">
      {guiones.map(g => (
        <a href={`/stripe-mocks/guion/${g.slug}`} class="card !p-4 hover:!shadow-lg transition-all block no-underline" style="text-decoration: none; background: var(--color-primary-soft);">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-2xl">{g.icon}</span>
            <h3 class="text-base font-bold !my-0" style="color: var(--color-graphite);">{g.title}</h3>
          </div>
          <p class="text-xs !my-0 italic" style="color: var(--color-stone);">{g.anchor}</p>
        </a>
      ))}
    </div>

    <h2 class="text-2xl font-bold mt-4 mb-4" style="color: var(--color-graphite);">🎙️ Entrevistas completas <span class="text-base font-normal" style="color: var(--color-stone);">· warm-up + trasplante</span></h2>
    <div class="grid md:grid-cols-2 gap-4 mb-12">
      {fullInterviews.map(iv => (
        <a href={`/stripe-mocks/${iv.slug}`} class="card !p-5 hover:!shadow-lg transition-all block no-underline" style="text-decoration: none;">
          <div class="flex items-start gap-3 mb-2">
            <span class="text-3xl">{iv.icon}</span>
            <div class="flex-1">
              <h3 class="text-lg font-bold !my-0" style="color: var(--color-graphite);">{iv.title}</h3>
              <p class="text-xs !my-1" style="color: var(--color-primary);">Trasplante: <strong>{iv.transplant}</strong></p>
            </div>
          </div>
          <p class="text-sm !mb-0" style="color: var(--color-stone);">{iv.summary}</p>
        </a>
      ))}
    </div>

    <h2 class="text-2xl font-bold mt-4 mb-4" style="color: var(--color-graphite);">🎯 Ángulos sobre productos <span class="text-base font-normal" style="color: var(--color-stone);">· improve, kill/invest, pricing, compete, métricas, scale</span></h2>
    <div class="grid md:grid-cols-2 gap-4 mb-12">
      {angles.map(a => (
        <a href={`/stripe-mocks/${a.slug}`} class="card !p-5 hover:!shadow-lg transition-all block no-underline" style="text-decoration: none;">
          <div class="flex items-start gap-3 mb-2">
            <span class="text-3xl">{a.icon}</span>
            <div class="flex-1">
              <h3 class="text-lg font-bold !my-0" style="color: var(--color-graphite);">{a.title}</h3>
              <p class="text-xs !my-1" style="color: var(--color-primary);">2 ángulos</p>
            </div>
          </div>
          <ul class="text-sm !mb-0 !mt-2 space-y-1" style="color: var(--color-stone);">
            <li>· {a.q1}</li>
            <li>· {a.q2}</li>
          </ul>
        </a>
      ))}
    </div>

    <h2 class="text-2xl font-bold mt-4 mb-4" style="color: var(--color-graphite);">✈️ Design-from-scratch <span class="text-base font-normal" style="color: var(--color-stone);">· ATM-style en distintos contextos</span></h2>
    <div class="grid md:grid-cols-2 gap-4 mb-12">
      {atms.map(a => (
        <a href={`/stripe-mocks/${a.slug}`} class="card !p-5 hover:!shadow-lg transition-all block no-underline" style="text-decoration: none;">
          <div class="flex items-start gap-3 mb-2">
            <span class="text-3xl">{a.icon}</span>
            <div class="flex-1">
              <h3 class="text-lg font-bold !my-0" style="color: var(--color-graphite);">{a.title}</h3>
            </div>
          </div>
          <p class="text-sm !mb-0" style="color: var(--color-stone);">{a.insight}</p>
        </a>
      ))}
    </div>

    <a href="/stripe-mocks/v4" class="card !p-6 mt-4 mb-4 block no-underline hover:!shadow-lg transition-all" style="background: linear-gradient(135deg, rgba(236,72,153,0.15), rgba(99,102,241,0.10)); border: 2px solid rgba(236,72,153,0.35); text-decoration: none;">
      <h3 class="!mt-0" style="color: var(--color-graphite);">🔥 V4 · Preparación final (28 May) · <span style="color: var(--color-primary);">3 productos + ATM aeropuerto + producto mal hecho →</span></h3>
      <p class="text-sm !mb-0" style="color: var(--color-stone);">Google Maps, LinkedIn, Claude Code (con traslación cada uno), diseño completo de ATM de aeropuerto, y crítica estructural de MyChildAtSchool. Formato unificado: usuarios → ecosistema → competidores → ventajas/desventajas → qué hacen bien / qué mejorar.</p>
    </a>

    <a href="/stripe-mocks/prioritisation" class="card !p-6 mt-4 mb-4 block no-underline hover:!shadow-lg transition-all" style="background: var(--color-primary-soft); text-decoration: none;">
      <h3 class="!mt-0" style="color: var(--color-graphite);">🎯 Prioritisation · <span style="color: var(--color-primary);">what to say if they ask "how would you prioritise this?" →</span></h3>
      <p class="text-sm !mb-0" style="color: var(--color-stone);">Structural answer + axes per product moment + worked example + lines under pressure. The trap to avoid: reciting RICE / MoSCoW.</p>
    </a>

    <a href="/stripe-mocks/patterns" class="card !p-6 mt-4 block no-underline hover:!shadow-lg transition-all" style="background: var(--color-primary-soft); text-decoration: none;">
      <h3 class="!mt-0" style="color: var(--color-graphite);">📋 Los 10 patrones · <span style="color: var(--color-primary);">desarrollados con ejemplos →</span></h3>
      <ol class="text-sm space-y-1 !mb-0 list-decimal list-inside" style="color: var(--color-stone);">
        <li>Define usuario primero, justifica.</li>
        <li>Sub-segmenta dentro del segmento.</li>
        <li>Mapea ecosistema antes que features.</li>
        <li>Pick a focus, dilo en voz alta.</li>
        <li>Conecta cada decisión con un sub-segmento.</li>
        <li>Nombra edge cases.</li>
        <li>Distingue Tiger de Paper Tiger.</li>
        <li>Cierra con métricas: target + leading/lagging + guard rail.</li>
        <li><strong>Si viene un trasplante:</strong> pausa, reconoce que el contexto cambia, nombra 2+ supuestos que se rompen.</li>
        <li><strong>Si te presionan:</strong> reformula con distinción más fina (consumer vs decisor, coste por turno vs por tarea), no defiendas la frase original.</li>
      </ol>
    </a>
  </div>
</LightLayout>
