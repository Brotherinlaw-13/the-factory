<html lang="en">
<head>
<meta charset="UTF-8"/>
<title>Finance System — Backlog</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f8f9fa;color:#1e293b;font-size:14px}
.top-nav{background:#fff;border-bottom:1px solid #e2e8f0;padding:10px 40px;font-size:13px;display:flex;gap:16px}
.top-nav a{color:#2563eb;text-decoration:none}
.ctr{max-width:1100px;margin:0 auto;padding:0 40px 60px}
.page-hdr{max-width:1100px;margin:0 auto;padding:28px 40px 0}
.page-hdr h1{font-size:26px;font-weight:800;margin-bottom:4px}
.page-hdr .desc{color:#64748b;font-size:14px;margin-bottom:8px}
.stats-bar{display:flex;gap:16px;margin:20px 0 28px;flex-wrap:wrap}
.stat-chip{background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:12px 20px;text-align:center;min-width:120px}
.stat-chip .num{font-size:22px;font-weight:700}.stat-chip .lbl{font-size:11px;color:#64748b;margin-top:2px}
.tier{margin-bottom:32px}
.tier-hdr{display:flex;align-items:center;gap:12px;margin-bottom:14px;padding-bottom:8px;border-bottom:2px solid #e2e8f0}
.tier-hdr h2{font-size:18px;font-weight:700}
.tier-hdr .cnt{background:#f1f5f9;color:#64748b;font-size:12px;font-weight:600;padding:2px 10px;border-radius:12px}
.tier-p0 .tier-hdr{border-bottom-color:#ef4444}.tier-p0 .tier-hdr h2{color:#dc2626}
.tier-p1 .tier-hdr{border-bottom-color:#f59e0b}.tier-p1 .tier-hdr h2{color:#d97706}
.tier-p2 .tier-hdr{border-bottom-color:#3b82f6}.tier-p2 .tier-hdr h2{color:#2563eb}
.tier-p3 .tier-hdr{border-bottom-color:#8b5cf6}.tier-p3 .tier-hdr h2{color:#7c3aed}
.tier-q .tier-hdr{border-bottom-color:#64748b}.tier-q .tier-hdr h2{color:#475569}
.ticket{background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:14px 18px;margin-bottom:10px;display:grid;grid-template-columns:72px 1fr auto;gap:12px;align-items:start;transition:box-shadow .15s}
.ticket:hover{box-shadow:0 2px 8px rgba(0,0,0,.07)}
.ticket-id{font-family:'SF Mono',Menlo,monospace;font-size:12px;font-weight:700;color:#64748b;padding-top:2px}
.ticket-body h3{font-size:14px;font-weight:600;margin-bottom:3px}
.ticket-body p{font-size:12px;color:#64748b;line-height:1.5}
.ticket-meta{display:flex;flex-direction:column;align-items:flex-end;gap:6px;min-width:120px}
.badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;white-space:nowrap}
.badge-green{background:#dcfce7;color:#166534}.badge-yellow{background:#fef9c3;color:#854d0e}.badge-red{background:#fee2e2;color:#991b1b}.badge-blue{background:#dbeafe;color:#1e40af}.badge-gray{background:#f1f5f9;color:#64748b}.badge-purple{background:#f3e8ff;color:#6b21a8}.badge-orange{background:#ffedd5;color:#9a3412}
.tag{font-size:11px;padding:2px 7px;border-radius:3px;background:#f1f5f9;color:#475569;white-space:nowrap}
.effort{font-size:11px;font-weight:700;width:22px;height:22px;border-radius:4px;display:flex;align-items:center;justify-content:center;background:#f1f5f9;color:#64748b}
.effort-s{background:#dcfce7;color:#166534}.effort-m{background:#fef9c3;color:#854d0e}.effort-l{background:#fee2e2;color:#991b1b}
.ticket-tags{display:flex;gap:4px;flex-wrap:wrap;align-items:center}
.q-ticket{background:#fff;border:1px solid #e2e8f0;border-left:3px solid #f59e0b;border-radius:4px;padding:12px 16px;margin-bottom:8px}
.q-ticket h3{font-size:13px;font-weight:600;margin-bottom:2px}.q-ticket p{font-size:12px;color:#64748b}
.legend{background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:16px 20px;margin-bottom:28px;display:flex;gap:20px;flex-wrap:wrap;font-size:12px;color:#64748b}
.legend-item{display:flex;align-items:center;gap:6px}
@media(max-width:700px){.ticket{grid-template-columns:1fr;gap:6px}.ticket-meta{flex-direction:row;align-items:center}.stats-bar{flex-direction:column}}
</style>
</head>
