  <!-- Enhanced JavaScript -->
  <script>
    // Enhanced marketplace functionality
    class AgentMarketplace {
      constructor() {
        this.selectedAgents = new Set();
        this.filteredAgents = [];
        this.allAgents = [];
        this.init();
      }

      init() {
        this.collectAgents();
        this.bindEvents();
        this.updateResults();
      }

      collectAgents() {
        this.allAgents = Array.from(document.querySelectorAll('.agent-card')).map(card => ({
          element: card,
          id: card.dataset.agentId,
          category: card.dataset.category,
          security: parseFloat(card.dataset.security),
          price: parseInt(card.dataset.price),
          rating: parseFloat(card.dataset.rating),
          name: card.dataset.name
        }));
        this.filteredAgents = [...this.allAgents];
      }

      bindEvents() {
        // Search functionality
        document.getElementById('agent-search').addEventListener('input', (e) => {
          this.handleSearch(e.target.value);
        });

        // Filter dropdowns
        ['category-filter', 'security-filter', 'price-sort'].forEach(id => {
          document.getElementById(id).addEventListener('change', () => {
            this.applyFilters();
          });
        });

        // Comparison functionality
        document.querySelectorAll('.compare-checkbox').forEach(checkbox => {
          checkbox.addEventListener('change', (e) => {
            this.handleCompareSelection(e);
          });
        });

        document.getElementById('compare-toggle').addEventListener('click', () => {
          this.toggleComparison();
        });

        document.getElementById('close-comparison').addEventListener('click', () => {
          this.closeComparison();
        });

        // Clear filters
        document.getElementById('clear-filters').addEventListener('click', () => {
          this.clearAllFilters();
        });
      }

      handleSearch(query) {
        const searchTerm = query.toLowerCase();
        this.filteredAgents = this.allAgents.filter(agent => {
          const name = agent.name.toLowerCase();
          const category = agent.category.toLowerCase();
          const text = agent.element.textContent.toLowerCase();
          
          return name.includes(searchTerm) || 
                 category.includes(searchTerm) || 
                 text.includes(searchTerm);
        });
        
        this.applyFilters();
      }

      applyFilters() {
        let filtered = [...this.filteredAgents];

        // Category filter
        const categoryFilter = document.getElementById('category-filter').value;
        if (categoryFilter) {
          filtered = filtered.filter(agent => agent.category === categoryFilter);
        }

        // Security filter
        const securityFilter = document.getElementById('security-filter').value;
        if (securityFilter) {
          const threshold = parseFloat(securityFilter.replace('+', ''));
          filtered = filtered.filter(agent => agent.security >= threshold);
        }

        // Price sorting
        const priceSort = document.getElementById('price-sort').value;
        if (priceSort === 'low') {
          filtered.sort((a, b) => a.price - b.price);
        } else if (priceSort === 'high') {
          filtered.sort((a, b) => b.price - a.price);
        }

        this.updateDisplay(filtered);
        this.updateResults();
      }

      updateDisplay(filtered) {
        // Hide all agents
        this.allAgents.forEach(agent => {
          agent.element.style.display = 'none';
        });

        // Show filtered agents with animation
        filtered.forEach((agent, index) => {
          agent.element.style.display = 'block';
          agent.element.style.animationDelay = `${index * 50}ms`;
          agent.element.classList.add('fade-in');
        });

        this.filteredAgents = filtered;
      }

      handleCompareSelection(e) {
        const card = e.target.closest('.agent-card');
        const agentId = card.dataset.agentId;

        if (e.target.checked) {
          if (this.selectedAgents.size >= 3) {
            e.target.checked = false;
            alert('You can only compare up to 3 agents at a time.');
            return;
          }
          this.selectedAgents.add(agentId);
          card.classList.add('selected');
        } else {
          this.selectedAgents.delete(agentId);
          card.classList.remove('selected');
        }

        this.updateCompareButton();
      }

      updateCompareButton() {
        const count = this.selectedAgents.size;
        document.getElementById('compare-count').textContent = count;
        
        const button = document.getElementById('compare-toggle');
        if (count === 0) {
          button.classList.remove('bg-purple-700');
          button.classList.add('bg-purple-600');
        } else {
          button.classList.remove('bg-purple-600');
          button.classList.add('bg-purple-700');
        }
      }

      toggleComparison() {
        if (this.selectedAgents.size === 0) {
          alert('Please select at least one agent to compare.');
          return;
        }

        const panel = document.getElementById('comparison-panel');
        panel.classList.remove('hidden');
        this.renderComparison();
      }

      renderComparison() {
        const grid = document.getElementById('comparison-grid');
        grid.innerHTML = '';

        this.selectedAgents.forEach(agentId => {
          const agent = this.allAgents.find(a => a.id === agentId);
          if (!agent) return;

          const comparisonCard = this.createComparisonCard(agent);
          grid.appendChild(comparisonCard);
        });
      }

      createComparisonCard(agent) {
        const card = document.createElement('div');
        card.className = 'comparison-card rounded-lg p-4';
        
        const originalCard = agent.element;
        const name = originalCard.querySelector('h3').textContent;
        const category = originalCard.querySelector('p').textContent;
        const security = agent.security;
        const price = agent.price;
        const rating = agent.rating;

        card.innerHTML = `
          <div class="text-center mb-4">
            <h4 class="font-semibold text-purple-900">${name}</h4>
            <p class="text-sm text-purple-600">${category}</p>
          </div>
          
          <div class="space-y-3">
            <div class="flex justify-between">
              <span class="text-sm text-gray-600">Security Score</span>
              <span class="font-medium text-green-600">${security}%</span>
            </div>
            
            <div class="flex justify-between">
              <span class="text-sm text-gray-600">Rating</span>
              <span class="font-medium text-yellow-600">${rating}/5</span>
            </div>
            
            <div class="flex justify-between">
              <span class="text-sm text-gray-600">Base Price</span>
              <span class="font-medium text-blue-600">${price} PACT</span>
            </div>
          </div>
          
          <button onclick="marketplace.removeFromComparison('${agent.id}')" class="w-full mt-4 px-3 py-2 bg-red-100 text-red-700 rounded text-sm hover:bg-red-200 transition-colors">
            Remove
          </button>
        `;

        return card;
      }

      removeFromComparison(agentId) {
        this.selectedAgents.delete(agentId);
        
        const checkbox = document.querySelector(`[data-agent-id="${agentId}"] .compare-checkbox`);
        if (checkbox) {
          checkbox.checked = false;
        }
        
        const card = document.querySelector(`[data-agent-id="${agentId}"]`);
        if (card) {
          card.classList.remove('selected');
        }
        
        this.updateCompareButton();
        
        if (this.selectedAgents.size === 0) {
          this.closeComparison();
        } else {
          this.renderComparison();
        }
      }

      closeComparison() {
        document.getElementById('comparison-panel').classList.add('hidden');
      }

      clearAllFilters() {
        document.getElementById('agent-search').value = '';
        document.getElementById('category-filter').value = '';
        document.getElementById('security-filter').value = '';
        document.getElementById('price-sort').value = '';
        
        this.filteredAgents = [...this.allAgents];
        this.updateDisplay(this.filteredAgents);
        this.updateResults();
      }

      updateResults() {
        const count = this.filteredAgents.length;
        document.getElementById('results-count').textContent = count;
        
        // Update filter summary
        const filters = [];
        const category = document.getElementById('category-filter').value;
        const security = document.getElementById('security-filter').value;
        const search = document.getElementById('agent-search').value;
        
        if (category) filters.push(`${category}`);
        if (security) filters.push(`${security} security`);
        if (search) filters.push(`"${search}"`);
        
        const summary = filters.length ? ` • Filtered by: ${filters.join(', ')}` : '';
        document.getElementById('filter-summary').textContent = summary;
      }
    }

    // Initialize marketplace when page loads
    let marketplace;
    document.addEventListener('DOMContentLoaded', () => {
      marketplace = new AgentMarketplace();
    });

    // Make removeFromComparison available globally for onclick
    window.removeFromComparison = (agentId) => {
      marketplace.removeFromComparison(agentId);
    };

    // Hero button functionality
    document.querySelector('.hero-marketplace-btn').addEventListener('click', () => {
      document.querySelector('#agent-grid').scrollIntoView({ behavior: 'smooth' });
    });
  </script>

</body>
</html>