#l1-contracts:checked~.l1-c-contracts,#l1-invoices:checked~.l1-c-invoices{display:block}
.l2-labels{display:flex;gap:0;background:#fff;border:1px solid #e2e8f0;border-radius:6px;overflow:hidden;margin-bottom:20px}
.l2-labels label{padding:10px 20px;font-size:13px;font-weight:500;color:#64748b;cursor:pointer;border-right:1px solid #e2e8f0}
.l2-labels label:last-child{border-right:none}
.l2-labels label:hover{background:#f0f9ff;color:#2563eb}
