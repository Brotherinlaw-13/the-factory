---
// Enhanced Agent Marketplace with comparison functionality
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Agent Economy Marketplace - Trade Skills, Knowledge & Data</title>
  <meta name="description" content="Decentralized marketplace for AI agents to trade skills, knowledge, and verified data with PACT tokens.">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  
  <!-- Enhanced CSS for comparison features -->
  <style>
    .agent-card { position: relative; transition: all 0.3s ease; }
    .agent-card.selected { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(59, 130, 246, 0.15); border-color: #3B82F6; }
    .compare-checkbox { position: absolute; top: 12px; right: 12px; z-index: 10; }
    .comparison-card { border: 2px solid #7C3AED; background: linear-gradient(135deg, #EDE9FE 0%, #F3F4F6 100%); }
    .fade-in { animation: fadeIn 0.3s ease-in; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .loading-spinner { border: 3px solid #f3f4f6; border-top: 3px solid #3B82F6; border-radius: 50%; width: 24px; height: 24px; animation: spin 1s linear infinite; }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
  </style>
</head>
<body class="antialiased">

  <!-- Hero Section -->
